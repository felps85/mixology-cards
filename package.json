{
  "name": "drinks",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf .next .next-dev .next-check .next-prod",
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "dev:clean": "npm run clean && NEXT_DIST_DIR=.next-dev next dev",
    "build": "NEXT_DIST_DIR=.next-prod next build",
    "build:check": "NEXT_DIST_DIR=.next-check next build",
    "start": "NEXT_DIST_DIR=.next-prod next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run test && npm run build:check",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --accept-data-loss",
    "db:setup": "npm run db:push && npm run db:seed",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "overrides": {
    "brace-expansion@^1.1.7": "1.1.13",
    "brace-expansion@^2.0.1": "2.0.3",
    "brace-expansion@^5.0.1": "5.0.5",
    "effect": "3.20.0",
    "glob": "10.5.0",
    "picomatch@^2.0.4": "2.3.2",
    "picomatch@^2.3.1": "2.3.2",
    "picomatch@^4.0.3": "4.0.4"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.3.1",
    "next": "^15.5.14",
    "next-auth": "^4.24.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.2",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}
